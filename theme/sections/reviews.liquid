{% if section.settings.show_section != false %}
<section id="reviews" class="section-reviews">
  <p class="eyebrow">{{ section.settings.eyebrow | default: 'WHAT THE RIDERS SAY' }}</p>
  <h2 class="section-reviews__heading">{{ section.settings.heading | default: 'From the dirt cult' }}</h2>

  <div class="section-reviews__grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars" aria-label="{{ block.settings.rating }} stars">
            {% for i in (1..block.settings.rating) %}★{% endfor %}
          </div>
          <p class="review-card__body">{{ block.settings.review }}</p>
          <div class="review-card__author">— {{ block.settings.author }}</div>
        </div>
      {% endfor %}
    {% else %}
      <div class="review-card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__body">"Best MTB kit I've owned. Tee keeps me cool on the climbs and the price doesn't mug me off. Sound."</p>
        <div class="review-card__author">— TAYLOR · TWEED VALLEY</div>
      </div>
      <div class="review-card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__body">"Durable, breathable, looks the part. Can't argue with that."</p>
        <div class="review-card__author">— JORDAN · PEAK DISTRICT</div>
      </div>
      <div class="review-card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__body">"Took it down Cwm Carn in pissing rain. Came back muddy. Tee was fine."</p>
        <div class="review-card__author">— SAM · SOUTH WALES</div>
      </div>
    {% endif %}
  </div>
</section>

{% endif %}

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHAT THE RIDERS SAY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the dirt cult" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "review", "label": "Review text", "default": "Great kit, well priced." },
        { "type": "text", "id": "author", "label": "Author", "default": "RIDER · LOCATION" }
      ]
    }
  ],
  "presets": [{ "name": "Reviews" }]
}
{% endschema %}
