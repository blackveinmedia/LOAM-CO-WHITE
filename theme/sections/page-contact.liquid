<div style="background:var(--loam-white)">
  <div style="background:var(--loam-black);padding:64px var(--space-6) 48px">
    <div style="max-width:900px;margin:0 auto">
      <p class="eyebrow" style="margin-bottom:16px">GET IN TOUCH</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(48px,7vw,88px);color:var(--loam-white);line-height:.95;letter-spacing:.02em">Contact</h1>
    </div>
  </div>

  <div style="max-width:1100px;margin:0 auto;padding:64px var(--space-6);display:grid;grid-template-columns:1fr 1.4fr;gap:80px;align-items:start">

    <!-- Left: info -->
    <div>
      <h2 style="font-family:var(--font-display);font-size:clamp(32px,4vw,48px);color:var(--loam-black);letter-spacing:.02em;margin-bottom:24px">We actually read the emails.</h2>
      <p style="font-size:15px;color:#E8E6E1;line-height:1.65;margin-bottom:40px">Got a question about sizing, an order, or just want to talk bikes? We get back to every message within 48 hours — usually much faster.</p>

      <div style="margin-bottom:32px">
        <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.15em;font-size:12px;color:#9A9A9A;margin-bottom:8px">GENERAL ENQUIRIES</p>
        <a href="mailto:ride.loamco@gmail.com" style="font-size:16px;color:var(--loam-black);font-weight:600;text-decoration:none">ride.loamco@gmail.com</a>
      </div>

      <div style="margin-bottom:32px">
        <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.15em;font-size:12px;color:#9A9A9A;margin-bottom:8px">RETURNS</p>
        <a href="mailto:ride.loamco@gmail.com" style="font-size:16px;color:var(--loam-black);font-weight:600;text-decoration:none">ride.loamco@gmail.com</a>
      </div>

      <div style="margin-bottom:32px">
        <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.15em;font-size:12px;color:#9A9A9A;margin-bottom:8px">AMBASSADOR PROGRAMME</p>
        <a href="mailto:ride.loamco@gmail.com" style="font-size:16px;color:var(--loam-black);font-weight:600;text-decoration:none">ride.loamco@gmail.com</a>
      </div>

      <div>
        <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.15em;font-size:12px;color:#9A9A9A;margin-bottom:12px">RESPONSE TIME</p>
        <p style="font-size:14px;color:#9A9A9A;line-height:1.55">We aim to reply to all messages within 48 hours on working days (Mon–Fri). Messages sent over the weekend will be answered Monday morning.</p>
      </div>
    </div>

    <!-- Right: form -->
    <div>
      {% form 'contact', id: 'contact-page-form' %}
        {% if form.posted_successfully %}
          <div style="background:var(--loam-neon);padding:24px;margin-bottom:32px">
            <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.12em;font-size:13px;color:#0A0A0A">MESSAGE SENT</p>
            <p style="font-size:14px;color:rgba(0,0,0,0.75);margin-top:4px">Thanks — we'll get back to you within 48 hours.</p>
          </div>
        {% endif %}

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
          <div>
            <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#9A9A9A;margin-bottom:6px">NAME *</label>
            <input type="text" name="contact[name]" required style="width:100%;border:1px solid #ccc;padding:12px;font-size:14px;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#9A9A9A;margin-bottom:6px">EMAIL *</label>
            <input type="email" name="contact[email]" required style="width:100%;border:1px solid #ccc;padding:12px;font-size:14px;box-sizing:border-box">
          </div>
        </div>

        <div style="margin-bottom:20px">
          <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#9A9A9A;margin-bottom:6px">SUBJECT</label>
          <select name="contact[subject]" style="width:100%;border:1px solid #ccc;padding:12px;font-size:14px;box-sizing:border-box;appearance:none;background:#fff">
            <option>Order enquiry</option>
            <option>Sizing help</option>
            <option>Returns / exchanges</option>
            <option>Crash replacement claim</option>
            <option>Ambassador programme</option>
            <option>Something else</option>
          </select>
        </div>

        <div style="margin-bottom:28px">
          <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#9A9A9A;margin-bottom:6px">MESSAGE *</label>
          <textarea name="contact[body]" rows="6" required style="width:100%;border:1px solid #ccc;padding:12px;font-size:14px;box-sizing:border-box;resize:vertical"></textarea>
        </div>

        <button type="submit" style="background:var(--loam-black);color:var(--loam-neon);font-family:var(--font-narrow);font-weight:700;font-size:13px;letter-spacing:.18em;padding:16px 32px;border:none;cursor:pointer;text-transform:uppercase;width:100%">SEND MESSAGE</button>
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
