{% if section.settings.show_section != false %}
<section class="section-newsletter">
  <div class="section-newsletter__inner">
    <div>
      <p class="section-newsletter__eyebrow">{{ section.settings.eyebrow | default: 'JOIN THE COMMUNITY' }}</p>
      <h2 class="section-newsletter__heading">{{ section.settings.heading | default: 'Join the dirt cult.' }}</h2>
    </div>
    <div>
      <p class="section-newsletter__body">{{ section.settings.body | default: 'Trail tips, product drops, and exclusive offers. No marketing fluff.' }}</p>

      {% if section.settings.mailchimp_action != blank %}
        <form action="{{ section.settings.mailchimp_action }}" method="post" class="newsletter-form" target="_blank" novalidate>
          <input type="hidden" name="b_{{ section.settings.mailchimp_u }}_{{ section.settings.mailchimp_id }}" tabindex="-1" value="">
          <input type="email" name="EMAIL" placeholder="{{ section.settings.placeholder | default: 'rider@trails.uk' }}" aria-label="Email address" required>
          <button type="submit">JOIN</button>
        </form>
      {% else %}
        {% form 'customer', id: 'newsletter-form', class: 'newsletter-form js-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'rider@trails.uk' }}" aria-label="Email address" required>
          <button type="submit">JOIN</button>
        {% endform %}
      {% endif %}

      <div class="newsletter-socials">
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener">
        {% else %}
          <a href="#" aria-label="Instagram">
        {% endif %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>
        </a>
        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" target="_blank" rel="noopener">
        {% else %}
          <a href="#" aria-label="TikTok">
        {% endif %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 4v10a4 4 0 1 1-4-4"/><path d="M14 4a4 4 0 0 0 4 4"/></svg>
        </a>
        {% if section.settings.youtube_url != blank %}
          <a href="{{ section.settings.youtube_url }}" aria-label="YouTube" target="_blank" rel="noopener">
        {% else %}
          <a href="#" aria-label="YouTube">
        {% endif %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="m10 9 5 3-5 3z" fill="currentColor"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

{% endif %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "JOIN THE COMMUNITY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the dirt cult." },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Trail tips, product drops, and exclusive offers. No marketing fluff." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "rider@trails.uk" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    {
      "type": "text",
      "id": "mailchimp_action",
      "label": "Mailchimp form action URL",
      "info": "Paste your Mailchimp list subscribe URL here (from Mailchimp embed code). Leave blank to use Shopify's built-in email capture."
    },
    { "type": "text", "id": "mailchimp_u", "label": "Mailchimp u value", "info": "Found in Mailchimp embed code: name=\"b_XXXX_...\"" },
    { "type": "text", "id": "mailchimp_id", "label": "Mailchimp list ID", "info": "Found in Mailchimp embed code: name=\"b_..._XXXX\"" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
