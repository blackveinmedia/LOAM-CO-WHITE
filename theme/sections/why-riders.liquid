{% liquid
  assign shield_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>'
  assign wind_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>'
  assign star_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  assign leaf_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>'
  assign mountain_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>'
  assign lightning_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>'
  assign compass_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>'
  assign fire_icon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>'
%}

<section id="why" class="section-why">
  <div class="section-why__header">
    <p class="eyebrow">{{ section.settings.eyebrow | default: 'WHY RIDERS CHOOSE LOAM CO.' }}</p>
    <h2 class="section-why__heading">{{ section.settings.heading | default: 'Four things, done properly.' }}</h2>
  </div>

  <div class="section-why__grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% liquid
          assign icon_name = block.settings.icon | default: 'shield'
          if icon_name == 'shield'
            assign icon_svg = shield_icon
          elsif icon_name == 'wind'
            assign icon_svg = wind_icon
          elsif icon_name == 'star'
            assign icon_svg = star_icon
          elsif icon_name == 'leaf'
            assign icon_svg = leaf_icon
          elsif icon_name == 'mountain'
            assign icon_svg = mountain_icon
          elsif icon_name == 'lightning'
            assign icon_svg = lightning_icon
          elsif icon_name == 'compass'
            assign icon_svg = compass_icon
          elsif icon_name == 'fire'
            assign icon_svg = fire_icon
          else
            assign icon_svg = shield_icon
          endif
        %}
        <div class="section-why__item" {{ block.shopify_attributes }}>
          <div class="section-why__num-row">
            <div class="section-why__num">{{ block.settings.number }}</div>
            <div class="section-why__icon" style="color:var(--loam-neon)">{{ icon_svg }}</div>
          </div>
          <div class="section-why__title">{{ block.settings.title }}</div>
          <div class="section-why__desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    {% else %}
      <div class="section-why__item">
        <div class="section-why__num-row">
          <div class="section-why__num">01</div>
          <div class="section-why__icon" style="color:var(--loam-neon)">{{ shield_icon }}</div>
        </div>
        <div class="section-why__title">TRAIL-TESTED DURABILITY</div>
        <div class="section-why__desc">Built to last in mud, rain, and dust. Tested in the South Wales Valleys before it ever ships.</div>
      </div>
      <div class="section-why__item">
        <div class="section-why__num-row">
          <div class="section-why__num">02</div>
          <div class="section-why__icon" style="color:var(--loam-neon)">{{ wind_icon }}</div>
        </div>
        <div class="section-why__title">BREATHABLE COMFORT</div>
        <div class="section-why__desc">Engineered fabrics designed for long climbs and longer descents.</div>
      </div>
      <div class="section-why__item">
        <div class="section-why__num-row">
          <div class="section-why__num">03</div>
          <div class="section-why__icon" style="color:var(--loam-neon)">{{ star_icon }}</div>
        </div>
        <div class="section-why__title">MODERN STYLE</div>
        <div class="section-why__desc">Ride gear that looks the part on the bike and at the pub afterwards.</div>
      </div>
      <div class="section-why__item">
        <div class="section-why__num-row">
          <div class="section-why__num">04</div>
          <div class="section-why__icon" style="color:var(--loam-neon)">{{ leaf_icon }}</div>
        </div>
        <div class="section-why__title">SUSTAINABLE CHOICE</div>
        <div class="section-why__desc">Recycled fabrics. Plastic-free packaging. No bullshit greenwashing.</div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Why Riders",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHY RIDERS CHOOSE LOAM CO." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Four things, done properly." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shield",
          "options": [
            { "value": "shield", "label": "Shield (durability)" },
            { "value": "wind", "label": "Wind (breathable)" },
            { "value": "star", "label": "Star (style)" },
            { "value": "leaf", "label": "Leaf (sustainable)" },
            { "value": "mountain", "label": "Mountain (trail)" },
            { "value": "lightning", "label": "Lightning (performance)" },
            { "value": "compass", "label": "Compass (explore)" },
            { "value": "fire", "label": "Fire (passion)" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "TRAIL-TESTED DURABILITY" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Built to last in mud, rain, and dust." }
      ]
    }
  ],
  "presets": [{ "name": "Why Riders" }]
}
{% endschema %}
