<div style="max-width:880px;margin:0 auto;padding:64px 48px">
  <h1 style="font-family:var(--font-display);font-size:clamp(48px,7vw,88px);text-transform:uppercase;line-height:0.9;margin-bottom:40px">
    {{ page.title }}
  </h1>
  <div style="font-size:16px;line-height:1.65;color:var(--loam-bone)">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page — Default",
  "settings": [],
  "presets": [
    { "name": "Page — Default" }
  ]
}
{% endschema %}
