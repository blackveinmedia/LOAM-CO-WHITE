{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="product-page">
  <div class="product-page__inner">
    <!-- Gallery -->
    <div class="product-page__gallery">
      <div class="product-page__main-image">
        {%- if product.featured_image -%}
          <img
            id="product-main-img"
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="1200" height="1200"
            loading="eager"
          >
        {%- else -%}
          <div class="product-card__placeholder" style="height:100%;display:flex;align-items:center;justify-content:center">
            {{ product.title | upcase }} · IMAGE
          </div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-page__thumbs">
          {%- for image in product.images limit: 4 -%}
            <div
              class="product-page__thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ image | image_url: width: 1200 }}"
            >
              <img
                src="{{ image | image_url: width: 300 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="300" height="300" loading="lazy"
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-page__info">
      {%- for collection in product.collections limit: 1 -%}
        <p class="eyebrow" style="margin-bottom:12px">{{ collection.title }}</p>
      {%- endfor -%}

      <h1 class="product-page__title">{{ product.title }}</h1>

      <div style="display:flex;align-items:baseline;gap:12px;margin-top:12px">
        <span class="product-page__price" id="product-price">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="product-page__compare-price" id="product-compare-price">{{ current_variant.compare_at_price | money }}</span>
        {%- else -%}
          <span class="product-page__compare-price" id="product-compare-price" style="display:none"></span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="product-page__desc">{{ product.description }}</div>
      {%- endif -%}

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="variant-selector">
            <span class="variant-selector__label">{{ option.name }}</span>
            <div class="variant-selector__options">
              {%- for value in option.values -%}
                {%- liquid
                  assign option_index = forloop.parentloop.index0
                  assign is_selected = false
                  if current_variant.options[option_index] == value
                    assign is_selected = true
                  endif

                  assign found_variant = nil
                  for variant in product.variants
                    if variant.options[option_index] == value
                      assign found_variant = variant
                      break
                    endif
                  endfor
                -%}
                <button
                  class="variant-option{% if is_selected %} is-selected{% endif %}{% unless found_variant.available %} is-unavailable{% endunless %}"
                  data-variant-id="{% if found_variant %}{{ found_variant.id }}{% endif %}"
                  data-price="{% if found_variant %}{{ found_variant.price }}{% endif %}"
                  data-compare-price="{% if found_variant %}{{ found_variant.compare_at_price }}{% endif %}"
                  data-available="{% if found_variant %}{{ found_variant.available }}{% else %}false{% endif %}"
                >
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      {%- if current_variant.available -%}
        <button
          class="product-add-to-cart"
          data-add-to-cart
          data-variant-id="{{ current_variant.id }}"
        >
          ADD TO CART
        </button>
      {%- else -%}
        <button class="product-add-to-cart" disabled>SOLD OUT</button>
      {%- endif -%}

      <p style="font-family:var(--font-mono);font-size:11px;color:var(--loam-ash);margin-top:16px;letter-spacing:.1em;text-transform:uppercase">
        FREE SHIPPING OVER £50 · EASY RETURNS
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Main",
  "settings": [],
  "presets": [
    { "name": "Product Main" }
  ]
}
{% endschema %}
