<div style="background:var(--loam-white)">

  <!-- Hero -->
  <div style="background:var(--loam-black);padding:64px var(--space-6) 48px">
    <div style="max-width:900px;margin:0 auto">
      <p class="eyebrow" style="margin-bottom:16px">CRASH REPLACEMENT</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(48px,8vw,96px);color:var(--loam-white);line-height:.9;letter-spacing:.02em;margin-bottom:24px">
        Crashes happen.<br><span style="color:var(--loam-neon)">40% off</span> when they do.
      </h1>
      <p style="font-size:18px;color:var(--loam-bone);max-width:580px;line-height:1.55">
        You're out there riding hard. Sometimes you go down. We don't think you should have to pay full price to replace the kit you trashed doing what you love.
      </p>
    </div>
  </div>

  <!-- How it works -->
  <div style="background:var(--loam-neon);padding:80px var(--space-6) 64px">
    <div style="max-width:1100px;margin:0 auto">
      <h2 style="font-family:var(--font-display);font-size:clamp(36px,5vw,64px);color:#0A0A0A;margin-bottom:40px;letter-spacing:.02em">How it works</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:40px;align-items:start">
        <div style="text-align:left">
          <div style="font-family:var(--font-display);font-size:72px;color:rgba(0,0,0,0.15);line-height:1;margin-bottom:16px">01</div>
          <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.12em;font-size:13px;color:#0A0A0A;margin-bottom:10px">CRASH YOUR KIT</p>
          <p style="font-size:14px;color:rgba(0,0,0,0.75);line-height:1.6">Your Loam Co. casual or ride wear takes the hit so your skin doesn't have to. That's what it's there for.</p>
        </div>
        <div style="text-align:left">
          <div style="font-family:var(--font-display);font-size:72px;color:rgba(0,0,0,0.15);line-height:1;margin-bottom:16px">02</div>
          <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.12em;font-size:13px;color:#0A0A0A;margin-bottom:10px">SUBMIT A CLAIM</p>
          <p style="font-size:14px;color:rgba(0,0,0,0.75);line-height:1.6">Fill in the form below with your order number and a photo of the damaged item. We'll review it within 48 hours.</p>
        </div>
        <div style="text-align:left">
          <div style="font-family:var(--font-display);font-size:72px;color:rgba(0,0,0,0.15);line-height:1;margin-bottom:16px">03</div>
          <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.12em;font-size:13px;color:#0A0A0A;margin-bottom:10px">GET 40% OFF</p>
          <p style="font-size:14px;color:rgba(0,0,0,0.75);line-height:1.6">Once approved, we'll email you a single-use 40% off discount code for the same item. Valid for 30 days.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Terms -->
  <div style="background:var(--loam-black);max-width:100%">
  <div style="max-width:800px;margin:0 auto;padding:64px var(--space-6) 48px;font-size:14px;color:var(--loam-bone);line-height:1.65">
    <h2 style="font-family:var(--font-narrow);font-weight:700;font-size:16px;letter-spacing:.12em;text-transform:uppercase;border-bottom:2px solid var(--loam-neon);padding-bottom:10px;margin-bottom:20px;color:var(--loam-white)">Terms &amp; conditions</h2>
    <ul style="padding-left:20px">
      <li style="margin-bottom:8px">Eligible items: all Loam Co. casual and ride wear (jerseys, trousers, tees, tops). Accessories, socks, and hats are excluded.</li>
      <li style="margin-bottom:8px">One claim per item, per customer, per 12-month period.</li>
      <li style="margin-bottom:8px">You must provide a photo of the crash-damaged item and your original Loam Co. order number.</li>
      <li style="margin-bottom:8px">The damage must be consistent with a genuine crash (tearing, abrasion, road rash) — normal wear and tear is not eligible.</li>
      <li style="margin-bottom:8px">Claims must be submitted within 60 days of the crash.</li>
      <li style="margin-bottom:8px">The 40% discount code applies to the same item only and cannot be combined with other promotions.</li>
      <li>We reserve the right to decline claims that do not meet the above criteria.</li>
    </ul>
  </div>
  </div>

  <!-- Claim form -->
  <div id="claim" style="background:#f5f5f5;padding:64px var(--space-6)">
    <div style="max-width:680px;margin:0 auto">
      <p style="font-family:var(--font-narrow);font-weight:700;letter-spacing:.18em;font-size:12px;color:#0A0A0A;margin-bottom:12px">SUBMIT A CLAIM</p>
      <h2 style="font-family:var(--font-display);font-size:clamp(36px,5vw,56px);color:#0A0A0A;margin-bottom:32px;letter-spacing:.02em">Make your claim</h2>

      {% form 'contact', id: 'crash-claim-form' %}
        <input type="hidden" name="contact[tags]" value="crash-replacement-claim">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
          <div>
            <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#333;margin-bottom:6px">NAME *</label>
            <input type="text" name="contact[name]" required style="width:100%;border:1px solid #ccc;background:#fff;padding:12px;font-size:14px;font-family:var(--font-body);box-sizing:border-box" placeholder="Sam Rider">
          </div>
          <div>
            <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#333;margin-bottom:6px">EMAIL *</label>
            <input type="email" name="contact[email]" required style="width:100%;border:1px solid #ccc;background:#fff;padding:12px;font-size:14px;font-family:var(--font-body);box-sizing:border-box" placeholder="you@trails.uk">
          </div>
        </div>

        <div style="margin-bottom:20px">
          <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#333;margin-bottom:6px">ORDER NUMBER *</label>
          <input type="text" name="contact[order_number]" required style="width:100%;border:1px solid #ccc;background:#fff;padding:12px;font-size:14px;font-family:var(--font-body);box-sizing:border-box" placeholder="#1234">
        </div>

        <div style="margin-bottom:20px">
          <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#333;margin-bottom:6px">ITEM DAMAGED *</label>
          <input type="text" name="contact[item]" required style="width:100%;border:1px solid #ccc;background:#fff;padding:12px;font-size:14px;font-family:var(--font-body);box-sizing:border-box" placeholder="e.g. Graft Jersey — Olive — M">
        </div>

        <div style="margin-bottom:20px">
          <label style="display:block;font-family:var(--font-narrow);font-size:11px;font-weight:700;letter-spacing:.18em;color:#333;margin-bottom:6px">DESCRIBE THE CRASH</label>
          <textarea name="contact[body]" rows="4" style="width:100%;border:1px solid #ccc;background:#fff;padding:12px;font-size:14px;font-family:var(--font-body);box-sizing:border-box;resize:vertical" placeholder="Where were you riding? What happened? Attach a photo of the damaged item by replying to the confirmation email we send you."></textarea>
        </div>

        <p style="font-size:12px;color:#666;margin-bottom:20px">After submitting, reply to the confirmation email with a photo of the damaged item. We review all claims within 48 hours.</p>

        <button type="submit" style="background:var(--loam-black);color:var(--loam-neon);font-family:var(--font-narrow);font-weight:700;font-size:13px;letter-spacing:.18em;padding:16px 32px;border:none;cursor:pointer;text-transform:uppercase;width:100%">SUBMIT CLAIM</button>
      {% endform %}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Crash Replacement",
  "settings": [],
  "presets": [{ "name": "Crash Replacement" }]
}
{% endschema %}
