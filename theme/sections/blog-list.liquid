<div class="blog-page" style="background:var(--loam-black);min-height:60vh;padding-bottom:80px">

  <!-- Hero -->
  <div style="background:var(--loam-black);border-bottom:1px solid rgba(0,0,0,0.08);padding:64px var(--space-6) 48px">
    <div style="max-width:1200px;margin:0 auto">
      <p class="eyebrow" style="margin-bottom:16px">{{ section.settings.eyebrow | default: 'LOAM CO.' }}</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(56px,8vw,96px);color:var(--loam-white);line-height:.95;letter-spacing:.02em;margin-bottom:24px">
        {{ blog.title | default: section.settings.heading | default: 'Blog' }}
      </h1>
      {% if blog.description != blank %}
        <p style="font-size:17px;color:var(--loam-bone);max-width:560px;line-height:1.55">{{ blog.description }}</p>
      {% else %}
        <p style="font-size:17px;color:var(--loam-bone);max-width:560px;line-height:1.55">{{ section.settings.description | default: 'Trail tips, kit news, and riding stories from the Loam Co. crew.' }}</p>
      {% endif %}
    </div>
  </div>

  <!-- Article Grid -->
  <div style="max-width:1200px;margin:0 auto;padding:64px var(--space-6) 0">
    {% if blog != blank and blog.articles_count > 0 %}
      <div class="section-journal__grid">
        {% for article in blog.articles %}
          <article itemscope itemtype="https://schema.org/BlogPosting">
            <a href="{{ article.url }}" class="article-card" aria-label="{{ article.title | escape }}">
              <div class="article-card__image">
                {% if article.image %}
                  <img
                    src="{{ article.image | image_url: width: 800 }}"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    loading="lazy" width="800" height="533"
                    itemprop="image">
                {% else %}
                  <div style="background:var(--loam-graphite);height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--font-narrow);font-size:11px;letter-spacing:.2em;color:var(--loam-ash)">LOAM CO. · BLOG</div>
                {% endif %}
              </div>
              {% if article.tags.size > 0 %}
                <div class="article-card__tag" itemprop="keywords">{{ article.tags.first | upcase }}</div>
              {% endif %}
              <h2 class="article-card__title" itemprop="headline">{{ article.title }}</h2>
              <div class="article-card__meta">
                <span itemprop="author">{{ article.author }}</span>
                <span> · </span>
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">{{ article.published_at | date: '%d %b %Y' }}</time>
                <span> · </span>
                <span>{{ article.content | strip_html | size | divided_by: 200 | plus: 1 }} min read</span>
              </div>
              {% if article.excerpt != blank %}
                <p style="font-size:14px;color:var(--loam-ash);margin-top:8px;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden" itemprop="description">
                  {{ article.excerpt | strip_html }}
                </p>
              {% endif %}
            </a>
          </article>
        {% endfor %}
      </div>

      <!-- Pagination -->
      {% if paginate.pages > 1 %}
        <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:64px">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" style="font-family:var(--font-narrow);font-size:12px;font-weight:700;letter-spacing:.18em;padding:12px 20px;border:2px solid rgba(0,0,0,0.15);color:var(--loam-white);text-decoration:none">← PREV</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" style="font-family:var(--font-narrow);font-size:12px;font-weight:700;letter-spacing:.18em;padding:12px 16px;border:2px solid rgba(0,0,0,0.15);color:var(--loam-white);text-decoration:none">{{ part.title }}</a>
            {% elsif part.title == paginate.current_page %}
              <span style="font-family:var(--font-narrow);font-size:12px;font-weight:700;letter-spacing:.18em;padding:12px 16px;border:2px solid var(--loam-neon);color:var(--loam-neon)">{{ part.title }}</span>
            {% else %}
              <span style="font-family:var(--font-narrow);font-size:12px;color:var(--loam-ash);padding:12px 16px">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" style="font-family:var(--font-narrow);font-size:12px;font-weight:700;letter-spacing:.18em;padding:12px 20px;border:2px solid rgba(0,0,0,0.15);color:var(--loam-white);text-decoration:none">NEXT →</a>
          {% endif %}
        </div>
      {% endif %}

    {% else %}
      <p style="color:var(--loam-ash);font-size:15px;text-align:center;padding:80px 0">No posts yet — check back soon.</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Blog List",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "LOAM CO." },
    { "type": "text", "id": "heading", "label": "Heading fallback", "default": "Blog" },
    { "type": "textarea", "id": "description", "label": "Description fallback", "default": "Trail tips, kit news, and riding stories from the Loam Co. crew." }
  ],
  "presets": [{ "name": "Blog List" }]
}
{% endschema %}
