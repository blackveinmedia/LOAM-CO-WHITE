<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#FFFFFF">

  {%- liquid
    if request.page_type == 'article'
      assign seo_title = article.title | append: ' | ' | append: shop.name
      assign seo_desc = article.excerpt_or_content | strip_html | strip_newlines | truncate: 160
      assign seo_image = article.image | image_url: width: 1200
    elsif request.page_type == 'blog'
      assign seo_title = blog.title | append: ' | ' | append: shop.name
      assign seo_desc = blog.description | default: shop.description
      assign seo_image = settings.share_image | image_url: width: 1200
    elsif request.page_type == 'product'
      assign seo_title = product.title | append: ' | ' | append: shop.name
      assign seo_desc = product.description | strip_html | truncate: 160
      assign seo_image = product.featured_image | image_url: width: 1200
    elsif request.page_type == 'collection'
      assign seo_title = collection.title | append: ' | ' | append: shop.name
      assign seo_desc = collection.description | strip_html | default: shop.description | truncate: 160
      assign seo_image = collection.image | image_url: width: 1200
    elsif request.page_type == 'index'
      assign seo_title = shop.name | append: ' | Mountain Bike Clothing & Gear'
      assign seo_desc = shop.description | default: 'UK-built mountain bike kit. No prestige tax. Designed and tested in the Tweed Valley.'
      assign seo_image = settings.share_image | image_url: width: 1200
    else
      assign seo_title = page_title | append: ' | ' | append: shop.name
      assign seo_desc = page_description | default: shop.description
      assign seo_image = settings.share_image | image_url: width: 1200
    endif
  -%}

  <title>{{ seo_title }}</title>
  <meta name="description" content="{{ seo_desc | escape }}">
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ seo_title | escape }}">
  <meta property="og:description" content="{{ seo_desc | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {% if request.page_type == 'article' %}
    <meta property="og:type" content="article">
    <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
    <meta property="article:author" content="{{ article.author }}">
  {% else %}
    <meta property="og:type" content="website">
  {% endif %}
  {% if seo_image != blank %}
    <meta property="og:image" content="{{ seo_image }}">
    <meta property="og:image:width" content="1200">
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ seo_title | escape }}">
  <meta name="twitter:description" content="{{ seo_desc | escape }}">
  {% if seo_image != blank %}
    <meta name="twitter:image" content="{{ seo_image }}">
  {% endif %}

  <!-- Organisation schema (all pages) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "logo": "{{ 'loam-logo.png' | asset_url }}"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Archivo+Narrow:wght@400;500;600;700&family=Archivo:wght@400;500&display=swap" rel="stylesheet">

  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body>
  {% section 'header' %}
  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  {% render 'cart-drawer' %}
  <script src="{{ 'loam.js' | asset_url }}" defer></script>
</body>
</html>
