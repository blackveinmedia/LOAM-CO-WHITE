<div class="cart-page">
  <h1 class="cart-page__heading">Your Bag</h1>

  {%- if cart.item_count == 0 -%}
    <div style="text-align:center;padding:80px 0">
      <p style="font-family:var(--font-mono);font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:var(--loam-ash)">
        BAG'S EMPTY. GET TO IT.
      </p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" style="margin-top:32px;display:inline-flex">
        SHOP NOW
      </a>
    </div>
  {%- else -%}
    <div class="cart-page__inner">
      <!-- Line items -->
      <div>
        {%- for item in cart.items -%}
          <div style="display:flex;gap:20px;padding:24px 0;border-bottom:1px solid var(--loam-charcoal)">
            <a href="{{ item.url }}" style="flex-shrink:0">
              {%- if item.image -%}
                <img
                  src="{{ item.image | image_url: width: 200 }}"
                  alt="{{ item.image.alt | escape }}"
                  width="100" height="100"
                  style="display:block;background:var(--loam-off-black)"
                >
              {%- else -%}
                <div style="width:100px;height:100px;background:var(--loam-off-black)"></div>
              {%- endif -%}
            </a>
            <div style="flex:1">
              <a href="{{ item.url }}" style="font-family:var(--font-display);font-size:24px;text-transform:uppercase;text-decoration:none;color:var(--loam-white)">{{ item.product.title }}</a>
              {%- unless item.variant.title == 'Default Title' -%}
                <p style="font-family:var(--font-mono);font-size:11px;color:var(--loam-ash);text-transform:uppercase;letter-spacing:.1em;margin-top:6px">{{ item.variant.title }}</p>
              {%- endunless -%}
              <p style="font-family:var(--font-mono);font-weight:700;font-size:16px;margin-top:8px">{{ item.line_price | money }}</p>
              <form action="{{ routes.cart_change_url }}" method="post" style="margin-top:10px;display:flex;align-items:center;gap:12px">
                <input type="hidden" name="line" value="{{ forloop.index }}">
                <label style="font-family:var(--font-narrow);font-weight:700;text-transform:uppercase;font-size:11px;letter-spacing:.14em;color:var(--loam-ash)">QTY</label>
                <input
                  type="number" name="quantity" value="{{ item.quantity }}" min="0"
                  style="width:60px;background:transparent;border:1px solid var(--loam-charcoal);color:var(--loam-white);padding:6px 10px;font-family:var(--font-mono);font-size:14px"
                >
                <button type="submit" style="font-family:var(--font-narrow);font-weight:700;text-transform:uppercase;font-size:11px;letter-spacing:.14em;background:none;border:0;color:var(--loam-neon);cursor:pointer">UPDATE</button>
              </form>
              <form action="{{ routes.cart_change_url }}" method="post" style="margin-top:6px">
                <input type="hidden" name="line" value="{{ forloop.index }}">
                <input type="hidden" name="quantity" value="0">
                <button type="submit" style="font-family:var(--font-narrow);font-weight:700;text-transform:uppercase;font-size:11px;letter-spacing:.14em;background:none;border:0;color:var(--loam-ash);cursor:pointer;text-decoration:underline">REMOVE</button>
              </form>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <!-- Summary -->
      <div style="background:var(--loam-off-black);border:2px solid var(--loam-charcoal);padding:28px;position:sticky;top:100px">
        <h2 style="font-family:var(--font-display);font-size:32px;text-transform:uppercase;margin-bottom:20px">ORDER SUMMARY</h2>
        <div style="display:flex;justify-content:space-between;padding-bottom:20px;border-bottom:1px solid var(--loam-charcoal)">
          <span style="font-family:var(--font-mono);font-size:13px;color:var(--loam-ash);text-transform:uppercase;letter-spacing:.1em">Subtotal</span>
          <span style="font-family:var(--font-mono);font-weight:700;font-size:18px">{{ cart.total_price | money }}</span>
        </div>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--loam-ash);text-transform:uppercase;letter-spacing:.1em;margin-top:16px;margin-bottom:20px">
          Shipping and tax calculated at checkout.
        </p>
        <a href="/checkout" class="btn btn--primary" style="width:100%;justify-content:center;font-size:15px;padding:20px">
          CHECKOUT
        </a>
        <a href="{{ routes.all_products_collection_url }}" style="display:block;text-align:center;font-family:var(--font-narrow);font-weight:700;text-transform:uppercase;font-size:12px;letter-spacing:.16em;color:var(--loam-ash);text-decoration:none;margin-top:16px">
          CONTINUE SHOPPING
        </a>
      </div>
    </div>
  {%- endif -%}
</div>
